{
  "realm": "originex",
  "enabled": true,
  "sslRequired": "none",
  "accessTokenLifespan": 3600,
  "registrationAllowed": false,

  "roles": {
    "realm": [
      { "name": "PLATFORM_ADMIN", "description": "Cross-tenant admin via system route (audited)" },
      { "name": "TENANT_ADMIN", "description": "User/role admin within a tenant" },
      { "name": "OPERATIONS", "description": "Disbursement ops, payment initiation" },
      { "name": "UNDERWRITER", "description": "Application decisioning, KYC verify" },
      { "name": "COLLECTIONS", "description": "Delinquency actions on overdue loans" },
      { "name": "FINANCE", "description": "GL postings, reconciliation" },
      { "name": "CUSTOMER_SUPPORT", "description": "Read + limited profile writes across the tenant's customers" },
      { "name": "AUDITOR", "description": "Read-only across domains" },
      { "name": "CUSTOMER", "description": "Borrower - own records only (subject-scoped)" }
    ]
  },

  "clientScopes": [
    {
      "name": "customers:read",
      "description": "Read customer records",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "customers:write",
      "description": "Create/update customer records",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "originex-tenant",
      "description": "Emits tenant_id and customer_id claims from user attributes",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "false", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "customer_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "customer_id",
            "claim.name": "customer_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],

  "clients": [
    {
      "clientId": "originex-web",
      "name": "Originex Web (human)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "defaultClientScopes": ["basic", "originex-tenant", "roles", "profile", "email"],
      "optionalClientScopes": ["customers:read", "customers:write"]
    },
    {
      "clientId": "svc-customer",
      "name": "Customer Service (machine)",
      "enabled": true,
      "publicClient": false,
      "secret": "svc-customer-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": ["basic", "roles"],
      "optionalClientScopes": ["customers:read", "customers:write"]
    }
  ],

  "users": [
    {
      "username": "customer-alice",
      "enabled": true,
      "email": "alice@tenant-a.example.com",
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Borrower",
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "attributes": {
        "tenant_id": ["11111111-1111-1111-1111-111111111111"],
        "customer_id": ["aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"]
      },
      "realmRoles": ["CUSTOMER"]
    },
    {
      "username": "customer-bob",
      "enabled": true,
      "email": "bob@tenant-b.example.com",
      "emailVerified": true,
      "firstName": "Bob",
      "lastName": "Borrower",
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "attributes": {
        "tenant_id": ["22222222-2222-2222-2222-222222222222"],
        "customer_id": ["bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb"]
      },
      "realmRoles": ["CUSTOMER"]
    },
    {
      "username": "staff-uma",
      "enabled": true,
      "email": "uma@tenant-a.example.com",
      "emailVerified": true,
      "firstName": "Uma",
      "lastName": "Underwriter",
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "attributes": {
        "tenant_id": ["11111111-1111-1111-1111-111111111111"]
      },
      "realmRoles": ["UNDERWRITER"]
    }
  ]
}
